# Financial Modeling Prep - Congress trade data (free tier: 250 calls/day)
FMP_API_KEY=your_fmp_api_key
# FMP budget: 200 for scheduled syncs (~every 14 min), 50 for fresh pulls
FMP_SCHEDULED_BUDGET=200
FMP_FRESH_BUDGET=50

# Alpaca - Paper trading by default (https://alpaca.markets)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=true

# Anthropic - AI Insights (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key

# Local RAG (sentence-transformers; no embedding API key). First run downloads the model (~80MB).
# USE_LOCAL_RAG=true
# ST_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_TOP_K=6

# Silver warehouse (SQLite ETL)
# WAREHOUSE_PATH=data/warehouse.db
# READ_FROM_WAREHOUSE=true
# ETL_STALE_SECONDS=7200
